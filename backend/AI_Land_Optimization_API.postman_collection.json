		{
			"name": "3. Optimization",
			"item": [
				{
					"name": "Optimize Layout - Quick Test (10 generations)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"land_input\": {\n    \"length\": 15,\n    \"width\": 10,\n    \"bedrooms\": 3,\n    \"toilets\": 2,\n    \"kitchen\": 1,\n    \"living_room\": 1,\n    \"dining_room\": 1,\n    \"garden_area\": 20,\n    \"parking_spaces\": 1,\n    \"balcony\": false,\n    \"front_direction\": \"north\",\n    \"road_side\": \"north\"\n  },\n  \"generations\": 10,\n  \"population_size\": 20,\n  \"mutation_rate\": 0.1,\n  \"crossover_rate\": 0.8\n}"
						},
						"url": {
							"raw": "http://localhost:8000/api/v1/optimization/optimize?save_to_db=true",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8000",
							"path": ["api", "v1", "optimization", "optimize"],
							"query": [
								{
									"key": "save_to_db",
									"value": "true",
									"description": "Save result to database"
								}
							]
						},
						"description": "Quick optimization test with 10 generations (fast, lower quality)"
					},
					"response": []
				},
