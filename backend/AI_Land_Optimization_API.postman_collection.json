							"mode": "raw",
							"raw": "{\n  \"length\": 15,\n  \"width\": 10,\n  \"bedrooms\": 3,\n  \"toilets\": 2,\n  \"kitchen\": 1,\n  \"living_room\": 1,\n  \"dining_room\": 1,\n  \"garden_area\": 20,\n  \"parking_spaces\": 1,\n  \"balcony\": false,\n  \"front_direction\": \"north\",\n  \"road_side\": \"north\"\n}"
