# AI Land Optimization Backend - Environment Variables Template
# Copy this file to .env and update with your actual values

# Application
APP_NAME="AI Land Optimization Backend"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT="development"

# API
API_HOST="0.0.0.0"
API_PORT=8000
API_PREFIX="/api/v1"

# Database (PostgreSQL)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL="postgresql://postgres:password@localhost:5432/land_optimization"
DATABASE_ECHO=False

# Redis Cache
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=3600

# Genetic Algorithm Parameters
GA_GENERATIONS=100
GA_POPULATION_SIZE=50
GA_MUTATION_RATE=0.1
GA_CROSSOVER_RATE=0.8
GA_TOURNAMENT_SIZE=3

# File Storage
OUTPUT_DIR="./output"
TEMP_DIR="./temp"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL="INFO"
LOG_FILE="./logs/app.log"
LOG_ROTATION="500 MB"
LOG_RETENTION="10 days"

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY="your-secret-key-change-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ENABLED=True

# Sri Lankan Building Rules
ENABLE_SRI_LANKAN_RULES=True
SETBACK_FRONT=3.0
SETBACK_SIDE=1.5
SETBACK_BACK=1.5
MAX_COVERAGE_PERCENT=65.0
